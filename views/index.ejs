<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShutterShare | Professional Camera Rentals</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('includes/header')%>
    <main>
        <section class="hero">
            <div class="hero-content">
                <h1>Capture Your Vision</h1>
                <p>High-end professional cameras, lenses, and equipment for rent. The right gear for your perfect shot is just a click away.</p>
                <a href="/products" class="btn btn-primary">Browse Gear</a>
            </div>
        </section>

        <section class="section">
            <div class="container">
                <h2 class="section-title">Featured Gear</h2>
                <div class="product-grid">
                    <div class="product-card">
                        <div class="product-image">
                             <img src="/uploads/index-2.webp"/>
                        </div>
                        <div class="product-info">
                            <h3>Nikon Z9</h3>
                            <p class="product-price">₹900 <span>/ day</span></p>
                            <a href="/products" class="btn btn-primary">Rent Now</a>
                        </div>
                    </div>
                    <div class="product-card">
                        <div class="product-image">
                            <img src="/uploads/index-1.webp"/>
                        </div>
                        <div class="product-info">
                            <h3>Canon EOS R5</h3>
                            <p class="product-price">₹850 <span>/ day</span></p>
                            <a href="/products" class="btn btn-primary">Rent Now</a>
                        </div>
                    </div>
                    <div class="product-card">
                        <div class="product-image">
                             <img src="/uploads/index-3.webp"/>
                        </div>
                        <div class="product-info">
                            <h3>Sony a7 IV</h3>
                            <p class="product-price">₹750 <span>/ day</span></p>
                            <a href="/products" class="btn btn-primary">Rent Now</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <footer class="main-footer">
        <div class="container">
            <p>&copy; 2025 LensLeap Rentals. All Rights Reserved. A College Project.</p>
        </div>
    </footer>

</body>
</html>