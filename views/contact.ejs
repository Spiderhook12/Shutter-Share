<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us | ShutterShare Rentals</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <%- include('includes/header')%>

    <main>
        <section class="section">
            <div class="container">
                <h2 class="section-title">Get In Touch</h2>
                <div class="content-wrapper">
                    <div class="contact-form">
                        <h3>Send Us a Message</h3>
                        <form action="/contact" method="post">
                            <% errors.forEach(errors=>{ %>
                                <p style="color:red"><%= errors %></p>
                                <% }) %>
                            <div class="form-group">
                                <label for="name">Full Name</label>
                                <input type="text" id="name" name="name" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" class="form-control" required>
                            </div>
                             <div class="form-group">
                                <label for="email">Subject</label>
                                <input type="text" id="subject" name="subject" class="form-control" required>
                            </div>
                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea id="message" name="message" rows="6" class="form-control" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Submit Message</button>
                        </form>
                    </div>
                    <div class="text-content">
                        <h3>Contact Information</h3>
                        <p>Have questions about gear or your rental? We're here to help. Reach out to us through any of the methods below.</p>
                        <p><strong>Email:</strong> support@lensleap.edu</p>
                        <p><strong>Phone:</strong> +91 12345 67890</p>
                        <p><strong>Location:</strong> College Campus Center, Room 101</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <footer class="main-footer">
        <div class="container">
            <p>&copy; 2025 LensLeap Rentals. All Rights Reserved. A College Project.</p>
        </div>
    </footer>

</body>
</html>