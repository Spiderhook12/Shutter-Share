<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Gear | ShutterShare Rentals</title>
    <link rel="stylesheet" href="/style.css">
    <style>
    /* Products page: show full image without cropping */
    .product-card {
        /* increase card height slightly to accommodate larger image */
        height: 490px;
    }

    .product-card .product-image {
        /* increase image container height a bit */
        height: 320px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #000; /* subtle letterbox background */
    }

    .product-card .product-image img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* ensure whole image is visible */
        object-position: center;
    }
    </style>
</head>
<body>

  <%- include('includes/header')%>

    <main>
        <section class="section">
            <div class="container">
                <h2 class="section-title">All Our Gear</h2>
                <div class="product-grid">
                  <% products.forEach(product => { %>
                    <div class="product-card" data-product-id="<%= product.id %>">
                      <div class="product-image">
                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                      </div>
                      <div class="product-info">
                        <div>
                          <h3><%= product.name %></h3>
                          <p class="product-description"><%= product.description %></p>
                          <% if (product.status) { %>
                            <span class="product-status status-<%= product.status %>">
                              <%= product.status.charAt(0).toUpperCase() + product.status.slice(1) %>
                            </span>
                          <% } %>
                        </div>
                        <div>
                          <div class="product-price">
                            ₹<%= product.price %> <span>/day</span>
                          </div>
                          
                          <% if (user && user.isAdmin) { %>
                            <!-- Admin sees Delete and Change Status buttons -->
                            <div class="admin-buttons">
                              <button class="btn btn-warning status-btn" 
                                      data-id="<%= product.id %>"
                                      data-name="<%= product.name %>"
                                      data-status="<%= product.status || 'available' %>"
                                      type="button">
                                Change Status
                              </button>
                              <button class="btn btn-danger delete-btn" 
                                      data-id="<%= product.id %>"
                                      type="button">
                                Delete Product
                              </button>
                            </div>
                          <% } else { %>
                            <!-- Regular users see Rent Now button only for available products -->
                            <% if (product.status === 'available' || !product.status) { %>
                              <button class="btn btn-primary rent-btn"
                                      data-id="<%= product.id %>"
                                      data-name="<%= product.name %>"
                                      data-description="<%= product.description %>"
                                      data-price="<%= product.price %>"
                                      data-image="<%= product.imageUrl %>"
                                      data-category="<%= product.category %>"
                                      type="button">
                                Rent Now
                              </button>
                            <% } else { %>
                              <button class="btn btn-primary" 
                                      disabled 
                                      style="background-color: #6c757d; cursor: not-allowed;">
                                Not Available
                              </button>
                            <% } %>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
            </div>
        </section>
    </main>
    
    <footer class="main-footer">
        <div class="container">
            <p>&copy; 2025 LensLeap Rentals. All Rights Reserved. A College Project.</p>
        </div>
    </footer>

    <!-- Product Modal (for regular users) -->
    <div id="productModal" class="modal">
      <div class="modal-content">
        <span class="close-modal">&times;</span>
        <div class="modal-product-details">
          <div class="modal-product-image">
            <img id="modalProductImage" src="" alt="Product Image">
          </div>
          <div class="modal-product-info">
            <div>
              <h2 id="modalProductName"></h2>
              <p class="modal-category" id="modalProductCategory"></p>
              <p class="modal-description" id="modalProductDescription"></p>
            </div>
            <div>
              <div class="modal-price">
                <span>₹</span><span id="modalProductPrice"></span><span>/day</span>
              </div>
              <button id="payButton" class="btn btn-primary payment-btn">Proceed to Payment</button>
              <div id="loginPrompt" class="login-prompt" style="display: none;">
                <p>Please <a href="/login">login</a> to rent this item.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Status Change Modal (for admins) -->
    <div id="statusModal" class="status-modal">
      <div class="status-modal-content">
        <h3>Change Product Status</h3>
        <p id="statusProductName" style="color: var(--text-gray); margin-bottom: 20px;"></p>
        <div class="status-options">
          <div class="status-option" data-status="available">
            <strong>Available</strong> - Product is ready to rent
          </div>
          <div class="status-option" data-status="rented">
            <strong>Rented</strong> - Product is currently rented out
          </div>
          <div class="status-option" data-status="maintenance">
            <strong>Maintenance</strong> - Product is under maintenance
          </div>
          <div class="status-option" data-status="unavailable">
            <strong>Unavailable</strong> - Product is not available
          </div>
        </div>
        <div class="status-modal-buttons">
          <button class="btn btn-danger" onclick="closeStatusModal()">Cancel</button>
          <button class="btn btn-primary" id="confirmStatusBtn">Update Status</button>
        </div>
      </div>
    </div>

    <!-- Add Razorpay Script -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <!-- Add Modal and Payment JavaScript -->
    <script>
    // Get modal elements
    const modal = document.getElementById('productModal');
    const closeBtn = document.getElementsByClassName('close-modal')[0];
    const statusModal = document.getElementById('statusModal');
    let currentProductData = {};
    let selectedStatus = '';
    let currentStatusProductId = null;

    // Function to open modal with product details
    function openProductModal(data) {
        console.log('Opening modal with data:', data);
        
        document.getElementById('modalProductName').textContent = data.name;
        document.getElementById('modalProductDescription').textContent = data.description;
        document.getElementById('modalProductPrice').textContent = data.price;
        document.getElementById('modalProductImage').src = data.image;
        document.getElementById('modalProductCategory').textContent = data.category;
        
        currentProductData = data;
        
        const isLoggedIn = <%= user ? 'true' : 'false' %>;
        const payButton = document.getElementById('payButton');
        const loginPrompt = document.getElementById('loginPrompt');
        
        if (isLoggedIn) {
            payButton.style.display = 'block';
            loginPrompt.style.display = 'none';
        } else {
            payButton.style.display = 'none';
            loginPrompt.style.display = 'block';
        }
        
        modal.style.display = "block";
        document.body.style.overflow = 'hidden';
    }

    // Function to close modal
    function closeModal() {
        modal.style.display = "none";
        document.body.style.overflow = 'auto';
    }

    // Function to open status modal
    function openStatusModal(productId, productName, currentStatus) {
        console.log('Opening status modal:', { productId, productName, currentStatus });
        
        currentStatusProductId = productId;
        selectedStatus = currentStatus; // Set initial selected status
        
        document.getElementById('statusProductName').textContent = 'Product: ' + productName;
        
        // Highlight current status
        document.querySelectorAll('.status-option').forEach(option => {
            option.classList.remove('selected');
            const optionStatus = option.getAttribute('data-status');
            if (optionStatus === currentStatus) {
                option.classList.add('selected');
            }
        });
        
        statusModal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    // Function to close status modal
    function closeStatusModal() {
        statusModal.style.display = 'none';
        document.body.style.overflow = 'auto';
        currentStatusProductId = null;
        selectedStatus = '';
    }

    // Initialize all event listeners when DOM is ready
    document.addEventListener('DOMContentLoaded', function() {
        console.log('Initializing event listeners...');
        
        // Attach click event to all "Rent Now" buttons
        const rentButtons = document.querySelectorAll('.rent-btn');
        rentButtons.forEach(function(button) {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                
                const productData = {
                    id: this.getAttribute('data-id'),
                    name: this.getAttribute('data-name'),
                    description: this.getAttribute('data-description'),
                    price: parseFloat(this.getAttribute('data-price')),
                    image: this.getAttribute('data-image'),
                    category: this.getAttribute('data-category')
                };
                
                openProductModal(productData);
            });
        });

        // Attach event to pay button
        const payButton = document.getElementById('payButton');
        if (payButton) {
            payButton.addEventListener('click', function() {
                if (currentProductData.id) {
                    initiatePayment(currentProductData.id, currentProductData.name, currentProductData.price);
                }
            });
        }

        // Close modal when clicking X
        if (closeBtn) {
            closeBtn.addEventListener('click', closeModal);
        }

        // Close modal when clicking outside
        window.addEventListener('click', function(event) {
            if (event.target === modal) {
                closeModal();
            }
            if (event.target === statusModal) {
                closeStatusModal();
            }
        });

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                if (modal.style.display === 'block') {
                    closeModal();
                }
                if (statusModal.style.display === 'block') {
                    closeStatusModal();
                }
            }
        });

        // Status option selection
        document.querySelectorAll('.status-option').forEach(option => {
            option.addEventListener('click', function() {
                console.log('Status option clicked');
                
                // Remove selected class from all options
                document.querySelectorAll('.status-option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                
                // Add selected class to clicked option
                this.classList.add('selected');
                
                // Store the selected status
                selectedStatus = this.getAttribute('data-status');
                console.log('Selected status:', selectedStatus);
            });
        });

        // Confirm status change
        const confirmStatusBtn = document.getElementById('confirmStatusBtn');
        if (confirmStatusBtn) {
            confirmStatusBtn.addEventListener('click', async function() {
                console.log('Confirm button clicked');
                console.log('Current product ID:', currentStatusProductId);
                console.log('Selected status:', selectedStatus);
                
                if (!selectedStatus || !currentStatusProductId) {
                    alert('Please select a status');
                    return;
                }
                
                try {
                    const response = await fetch(`/products/${currentStatusProductId}/status`, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ status: selectedStatus })
                    });
                    
                    console.log('Response status:', response.status);
                    
                    const data = await response.json();
                    console.log('Response data:', data);
                    
                    if (data.success) {
                        // Update the status badge in the UI
                        const productCard = document.querySelector(`[data-product-id="${currentStatusProductId}"]`);
                        if (productCard) {
                            const statusBadge = productCard.querySelector('.product-status');
                            
                            if (statusBadge) {
                                statusBadge.className = `product-status status-${selectedStatus}`;
                                statusBadge.textContent = selectedStatus.charAt(0).toUpperCase() + selectedStatus.slice(1);
                            }
                            
                            // Update the data attribute in the status button
                            const statusBtn = productCard.querySelector('.status-btn');
                            if (statusBtn) {
                                statusBtn.setAttribute('data-status', selectedStatus);
                            }
                        }
                        
                        alert('Status updated successfully!');
                        closeStatusModal();
                        
                        // Optional: reload page to ensure everything is in sync
                        // location.reload();
                    } else {
                        alert('Failed to update status: ' + (data.message || 'Unknown error'));
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('Error updating status. Check console for details.');
                }
            });
        }

        // Admin: Status change buttons
        document.querySelectorAll('.status-btn').forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault(); // Prevent any default action
                console.log('Status button clicked');
                
                const productId = this.getAttribute('data-id');
                const productName = this.getAttribute('data-name');
                const currentStatus = this.getAttribute('data-status') || 'available';
                
                console.log('Button data:', { productId, productName, currentStatus });
                
                openStatusModal(productId, productName, currentStatus);
            });
        });

        // Admin: Delete buttons (enhanced)
        document.querySelectorAll('.delete-btn').forEach(button => {
            button.addEventListener('click', async function(e) {
                e.preventDefault(); // Prevent default action
                
                const productId = this.dataset.id || this.getAttribute('data-id');
                const productCard = this.closest('.product-card');
                
                console.log('Delete button clicked for product ID:', productId); // Debug log
                
                if (!productId) {
                    alert('Error: Product ID not found');
                    return;
                }
                
                if (confirm('Are you sure you want to delete this product? This action cannot be undone.')) {
                    try {
                        console.log('Sending DELETE request to:', `/products/${productId}`); // Debug log
                        
                        const response = await fetch(`/products/${productId}`, {
                            method: 'DELETE',
                            credentials: 'include',
                            headers: {
                                'Accept': 'application/json',
                                'Content-Type': 'application/json'
                            }
                        });
                        
                        console.log('Response status:', response.status); // Debug log
                        
                        let data;
                        try {
                            data = await response.json();
                        } catch (parseErr) {
                            console.warn('Failed to parse JSON response');
                            data = { success: false, message: 'Non-JSON response from server' };
                        }

                        if (!response.ok) {
                            const msg = data && data.message ? data.message : `HTTP error! status: ${response.status}`;
                            throw new Error(msg);
                        }

                        console.log('Response data:', data); // Debug log
                        
                        if (data.success) {
                            // Remove the product card from the DOM with fade-out
                            if (productCard) {
                                productCard.style.transition = 'opacity 0.3s ease';
                                productCard.style.opacity = '0';
                                setTimeout(() => {
                                    productCard.remove();
                                }, 300);
                            }
                            alert('Product deleted successfully');
                        } else {
                            alert('Error deleting product: ' + (data.message || 'Unknown error'));
                        }
                    } catch (error) {
                        console.error('Error during delete:', error);
                        alert('Error deleting product: ' + error.message);
                    }
                }
            });
        });
    });

    // Payment function
    function initiatePayment(productId, productName, amount) {
        const payButton = document.getElementById('payButton');
        payButton.disabled = true;
        payButton.textContent = 'Processing...';

        fetch('/create-order', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                productId: productId,
                amount: amount
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.error) {
                throw new Error(data.error);
            }

            const options = {
                key: data.key,
                amount: data.amount,
                currency: data.currency,
                name: 'ShutterShare Rentals',
                description: 'Rent: ' + productName,
                order_id: data.orderId,
                handler: function(response) {
                    verifyPayment(response, productId, amount);
                },
                prefill: {
                    <% if (user) { %>
                    email: '<%= user.mail %>',
                    <% } %>
                },
                theme: {
                    color: '#FFDD00'
                },
                modal: {
                    ondismiss: function() {
                        payButton.disabled = false;
                        payButton.textContent = 'Proceed to Payment';
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();

            payButton.disabled = false;
            payButton.textContent = 'Proceed to Payment';
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to create payment order. Please try again.');
            payButton.disabled = false;
            payButton.textContent = 'Proceed to Payment';
        });
    }

    // Verify payment
    function verifyPayment(response, productId, amount) {
        fetch('/process-payment', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                productId: productId,
                paymentId: response.razorpay_payment_id,
                orderId: response.razorpay_order_id,
                signature: response.razorpay_signature,
                amount: amount
            })
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                alert('🎉 Payment successful! Your rental is confirmed.\n\nPayment ID: ' + response.razorpay_payment_id);
                closeModal();
                // Reload the page to show updated status
                location.reload();
            } else {
                alert('Payment verification failed. Please contact support.');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('There was an error verifying your payment.');
        });
    }
    </script>
</body>
</html>